# Database - Neon Postgres connection string
# Get yours at https://neon.tech (free tier available)
# The code accepts any of: POSTGRES_URL, DATABASE_URL, or POSTGRES_PRISMA_URL
POSTGRES_URL=postgresql://user:password@host/database?sslmode=require

# Admin password for viewing RSVPs at /admin
ADMIN_PASSWORD=choose-a-strong-password
